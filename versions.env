# AI Gateway data-plane image pin (ADR-017: agentgateway, replacing Portkey OSS).
#
# AGENTGATEWAY_REF        — upstream image tag built/published by the
#                           agentgateway project (github.com/agentgateway/agentgateway).
# AGENTGATEWAY_VERSION    — human-readable label for our build (image tags, docs).
# AGENTGATEWAY_IMAGE_DIGEST — sha256 digest of the upstream image, pinned for
#                           supply-chain integrity. Our Dockerfile re-tags the
#                           upstream image BY DIGEST into our ECR; the digest is
#                           the immutable contract, the tag is informational.
#
# We pin the upstream multi-arch image by digest rather than building the Rust
# binary from source: agentgateway publishes a hardened distroless image
# (cgr.dev/chainguard/glibc-dynamic base), so re-tagging by digest is both
# smaller-surface and faster than reproducing the Rust toolchain build here.
#
# Update path: bump AGENTGATEWAY_REF + AGENTGATEWAY_IMAGE_DIGEST together. The
# data-plane-image-scanner workflow (replacing portkey-release-scanner) watches
# upstream releases and opens a PR with the new digest.
AGENTGATEWAY_REF=v1.3.1
AGENTGATEWAY_VERSION=1.3.1
# Digest of the upstream multi-arch image (linux/amd64 + linux/arm64 OCI index),
# resolved 2026-06-30 and verified against `docker pull` of the same ref. The
# digest is the immutable supply-chain contract; the tag is informational.
# Re-resolve when bumping AGENTGATEWAY_REF:
#   docker buildx imagetools inspect ghcr.io/agentgateway/agentgateway:<ref>
AGENTGATEWAY_IMAGE_DIGEST=sha256:c3ce7b75da90fef70239befcc1c3adc05152d7b9dd21fcb8351178026a2c4381
