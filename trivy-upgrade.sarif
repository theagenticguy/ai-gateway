          "rules": [
            {
              "id": "CVE-2026-45736",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "ws is an open source WebSocket client and server for Node.js. Prior to ..."
              },
              "fullDescription": {
                "text": "ws is an open source WebSocket client and server for Node.js. Prior to 8.20.1, the websocket.close() implementation is vulnerable to uninitialized memory disclosure when a TypedArray is passed as the reason argument. This vulnerability is fixed in 8.20.1."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "helpUri": "https://avd.aquasec.com/nvd/cve-2026-45736",
              "help": {
                "text": "Vulnerability CVE-2026-45736\nSeverity: MEDIUM\nPackage: ws\nFixed Version: 8.20.1\nLink: [CVE-2026-45736](https://avd.aquasec.com/nvd/cve-2026-45736)\nws is an open source WebSocket client and server for Node.js. Prior to 8.20.1, the websocket.close() implementation is vulnerable to uninitialized memory disclosure when a TypedArray is passed as the reason argument. This vulnerability is fixed in 8.20.1.",
                "markdown": "**Vulnerability CVE-2026-45736**\n| Severity | Package | Fixed Version | Link |\n| --- | --- | --- | --- |\n|MEDIUM|ws|8.20.1|[CVE-2026-45736](https://avd.aquasec.com/nvd/cve-2026-45736)|\n\nws is an open source WebSocket client and server for Node.js. Prior to 8.20.1, the websocket.close() implementation is vulnerable to uninitialized memory disclosure when a TypedArray is passed as the reason argument. This vulnerability is fixed in 8.20.1."
              },
              "properties": {
                "cvssv3_baseScore": 4.4,
                "cvssv3_vector": "CVSS:3.1/AV:N/AC:H/PR:H/UI:N/S:U/C:H/I:N/A:N",
                "precision": "very-high",
                "security-severity": "4.4",
                "tags": [
                  "vulnerability",
